<smil>
    <head>
        <meta http-equiv="Refresh" content="90"/>
        <meta log="true" type="manual" endpoint="http://localhost:3000/report"/>
        <layout>
            <root-layout width="1080" height="1920"/>
            <region regionName="main" left="0" top="0" width="1920" height="1080" z-index="1"/>
        </layout>
    </head>
    <body>
        <par repeatCount="indefinite">
            <seq repeatCount="indefinite">
                <video src="http://localhost:3000/assets/landscape1.mp4"
                       region="main" soundLevel="0%"
                       popName="videoEvent" popType="video"
                       popTags="tag1,tag2"/>
                <img dur="3s"
                     src="http://localhost:3000/assets/landscape1.jpg"
                     region="main" fit="fill"
                     popName="imageEvent" popType="image"
                     popTags="tag3,tag4"/>
            </seq>
        </par>
    </body>
</smil>
