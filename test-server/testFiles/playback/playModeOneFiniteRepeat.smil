<smil>
    <head>
        <meta http-equiv="refresh" content="300"/>
        <layout>
            <root-layout width="1920" height="1080" backgroundColor="#000000"/>
            <region regionName="main" left="0" top="0" width="1920" height="1080" z-index="1"/>
        </layout>
    </head>
    <body>
        <par>
            <seq end="__prefetchEnd.endEvent">
                <seq repeatCount="indefinite">
                    <video src="https://demo.signageos.io/smil/samples/assets/loader.mp4"/>
                </seq>
            </seq>
            <seq>
                <prefetch src="https://demo.signageos.io/smil/zones/files/img_1.jpg"/>
                <prefetch src="https://demo.signageos.io/smil/zones/files/img_2.jpg"/>
                <prefetch src="https://demo.signageos.io/smil/zones/files/img_3.jpg"/>
                <seq id="__prefetchEnd" dur="1s"/>
            </seq>
            <par begin="__prefetchEnd.endEvent">
                <seq repeatCount="2">
                    <seq playMode="one">
                        <seq>
                            <img dur="2s"
                                 src="https://demo.signageos.io/smil/zones/files/img_1.jpg"
                                 region="main" fit="fill"/>
                        </seq>
                        <seq>
                            <img dur="2s"
                                 src="https://demo.signageos.io/smil/zones/files/img_2.jpg"
                                 region="main" fit="fill"/>
                        </seq>
                        <seq>
                            <img dur="2s"
                                 src="https://demo.signageos.io/smil/zones/files/img_3.jpg"
                                 region="main" fit="fill"/>
                        </seq>
                    </seq>
                </seq>
            </par>
        </par>
    </body>
</smil>
