<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<!--
  Minimal ticker fixture for test-runner/playback/ticker.test.ts — the
  e2e smoke test that proves the ticker render + animation pipeline works.
  One region, one ticker with two short text items. Kept as small as
  possible so the test boots fast and the only moving parts are the
  ticker spans (no loader video, no widgets, no priority).
-->
<smil>
	<head>
		<layout>
			<root-layout width="1920" height="1080"/>
			<region regionName="main" left="0" top="0" width="1920" height="200" z-index="1"/>
		</layout>
	</head>
	<body>
		<par repeatCount="indefinite">
			<ticker region="main" dur="60s" fontName="Arial" fontSize="40"
			        fontColor="#ffffff" backgroundColor="#000000"
			        indentation="50" velocity="100">
				<text>Hello ticker world.</text>
				<text>This is the second text item.</text>
			</ticker>
		</par>
	</body>
</smil>
