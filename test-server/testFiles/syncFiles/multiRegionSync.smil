<?xml version="1.0" encoding="UTF-8"?>
<smil>
    <head>
        <meta http-equiv="refresh" content="300"/>
        <layout>
            <root-layout width="1920" height="1080" backgroundColor="#000000"/>
            <region regionName="top" left="0" top="0" width="1920" height="540" sync="true"/>
            <region regionName="bottom" left="0" top="540" width="1920" height="540" sync="true"/>
        </layout>
    </head>
    <body>
        <par>
            <seq end="__prefetchEnd.endEvent">
                <seq repeatCount="indefinite">
                    <video src="https://demo.signageos.io/smil/samples/assets/loader.mp4"/>
                </seq>
            </seq>
            <seq>
                <prefetch src="https://demo.signageos.io/smil/samples/assets/landscape1.jpg"/>
                <prefetch src="https://demo.signageos.io/smil/samples/assets/landscape2.jpg"/>
                <seq id="__prefetchEnd" dur="1s"/>
            </seq>
            <par begin="__prefetchEnd.endEvent" repeatCount="indefinite">
                <!-- top region: 4 s cadence -->
                <seq repeatCount="indefinite">
                    <img dur="4s" src="https://demo.signageos.io/smil/samples/assets/landscape1.jpg" region="top" fit="fill"/>
                    <img dur="4s" src="https://demo.signageos.io/smil/samples/assets/landscape2.jpg" region="top" fit="fill"/>
                </seq>
                <!-- bottom region: 6 s cadence so the two regions go out of phase and
                     both schedulers are clearly independent -->
                <seq repeatCount="indefinite">
                    <img dur="6s" src="https://demo.signageos.io/smil/samples/assets/landscape2.jpg" region="bottom" fit="fill"/>
                    <img dur="6s" src="https://demo.signageos.io/smil/samples/assets/landscape1.jpg" region="bottom" fit="fill"/>
                </seq>
            </par>
        </par>
    </body>
</smil>
