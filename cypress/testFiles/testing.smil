<smil>
    <head>
        <layout>
            <root-layout width="1080" height="1920" backgroundColor="#FFFFFF"></root-layout>
            <region regionName="fullscreen" left="0" top="0" width="1080" height="1920" z-index="1" backgroundColor="#000000" sync="true"></region>
        </layout>

        <meta log="true" type="manual" endpoint="https://pop-server.signage-cdn.com/api/data" reportFileLimit="10"  />
        <meta http-equiv="Refresh" content="60" timeOut="5000" fallbackToPreviousPlaylist="true" onlySmilUpdate="false" checkBeforePlay="true" checkAheadCount="3" skipContentOnHttpStatus="404" smilFileRefresh="604800" updateMechanism="location"></meta>
        <meta defaultRepeatCount="indefinite"></meta>
    </head>
    <body>
        <seq>
            <video src="http://165.227.174.219:4000/screen/1/content?screen=1&amp;id=1"  region="fullscreen"></video>
            <video src="http://165.227.174.219:4000/screen/1/content?screen=1&amp;id=2"  region="fullscreen"></video>
